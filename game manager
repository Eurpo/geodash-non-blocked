using UnityEngine;

public class PlayerMovement : MonoBehaviour
{
    [Header("Physics Settings")]
    public float moveSpeed = 8f;
    public float jumpForce = 15f;
    
    private Rigidbody2D rb;
    private bool isGrounded;

    void Start()
    {
        rb = GetComponent<Rigidbody2D>();
    }

    void Update()
    {
        // Keep moving right at a constant speed, preserve whatever the current Y velocity (falling/jumping) is
        rb.velocity = new Vector2(moveSpeed, rb.velocity.y);

        // Jump logic: Press Space, Up Arrow, or Left Mouse Button
        if ((Input.GetKeyDown(KeyCode.Space) || Input.GetKeyDown(KeyCode.UpArrow) || Input.GetMouseButtonDown(0)) && isGrounded)
        {
            // Instead of adding force, we INSTANTLY set the Y velocity. 
            // This makes every single jump exactly the same height.
            rb.velocity = new Vector2(rb.velocity.x, jumpForce);
        }
    }

    // --- Ground Detection ---
    // Make sure your floor objects are set to the tag "Ground" in the Unity Inspector!
    void OnCollisionEnter2D(Collision2D collision)
    {
        if (collision.gameObject.CompareTag("Ground") || collision.gameObject.CompareTag("Block"))
        {
            isGrounded = true;
        }
    }

    void OnCollisionExit2D(Collision2D collision)
    {
        if (collision.gameObject.CompareTag("Ground") || collision.gameObject.CompareTag("Block"))
        {
            isGrounded = false;
        }
    }
}
